# N8N Configuration
N8N_HOSTNAME={{ n8n.hostname }}
WEBHOOK_URL=https://{{ n8n.hostname }}
N8N_ENCRYPTION_KEY={{ n8n_encryption_key }}
N8N_USER_MANAGEMENT_JWT_SECRET={{ n8n_jwt_secret }}
N8N_API_KEY={{ n8n_api_key }}
N8N_WORKER_COUNT={{ n8n.worker_count | default(1) }}
N8N_DIAGNOSTICS_ENABLED=false
N8N_PERSONALIZATION_ENABLED=false
RUN_N8N_IMPORT=false

# Database Configuration
POSTGRES_VERSION=16
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER={{ postgres_user }}
POSTGRES_PASSWORD={{ postgres_password }}
POSTGRES_DB={{ postgres_db }}

# Evolution API DB
EVOLUTION_DB_USER={{ evolution_db_user }}
EVOLUTION_DB_PASSWORD={{ evolution_db_password }}
EVOLUTION_DB_NAME={{ evolution_db_name }}

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# Qdrant Configuration
{% if n8n.enable_qdrant | default(false) %}
QDRANT_HOSTNAME={{ qdrant.hostname }}
QDRANT_API_KEY={{ qdrant_api_key }}
{% endif %}

# pgAdmin Configuration
PGADMIN_DEFAULT_EMAIL={{ pgadmin_default_email }}
PGADMIN_DEFAULT_PASSWORD={{ pgadmin_default_password }}
PGADMIN_HOSTNAME={{ pgadmin_hostname }}
PGWEB_HOSTNAME=pgweb.{{ server_domain }}

# Langfuse Configuration
{% if n8n.enable_langfuse | default(false) %}
LANGFUSE_HOSTNAME={{ langfuse.hostname }}
LANGFUSE_DB_USER={{ langfuse_db_user }}
LANGFUSE_DB_PASSWORD={{ langfuse_db_password }}
LANGFUSE_DB_NAME={{ langfuse_db_name }}
LANGFUSE_SALT={{ langfuse_salt }}
ENCRYPTION_KEY={{ langfuse_encryption_key }}
NEXTAUTH_SECRET={{ nextauth_secret }}
CLICKHOUSE_PASSWORD={{ clickhouse_password }}
MINIO_ROOT_PASSWORD={{ minio_root_password }}
TELEMETRY_ENABLED=false
LANGFUSE_ENABLE_EXPERIMENTAL_FEATURES=true

LANGFUSE_INIT_ORG_ID={{ langfuse_init_org_id | default('organization_id') }}
LANGFUSE_INIT_ORG_NAME={{ langfuse_init_org_name | default('Organization') }}
LANGFUSE_INIT_PROJECT_ID={{ langfuse_init_project_id | default('project_id') }}
LANGFUSE_INIT_PROJECT_NAME={{ langfuse_init_project_name | default('Project') }}
LANGFUSE_INIT_PROJECT_PUBLIC_KEY={{ langfuse_init_project_public_key | default('') }}
LANGFUSE_INIT_PROJECT_SECRET_KEY={{ langfuse_init_project_secret_key | default('') }}
LANGFUSE_INIT_USER_EMAIL={{ langfuse_init_user_email | default('') }}
LANGFUSE_INIT_USER_NAME={{ langfuse_init_user_name | default('') }}
LANGFUSE_INIT_USER_PASSWORD={{ langfuse_init_user_password | default('') }}
{% endif %}

# Docker
DOCKER_SOCKET_LOCATION=/var/run/docker.sock
N8N_DATA_PATH={{ n8n_data_path }}
